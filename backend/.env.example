# LegalLens — Phase 1 Environment Variables

# OpenAI (for embeddings + LLM)
OPENAI_API_KEY=sk-...

# Alternatively, use Anthropic Claude as LLM
ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=openai   # or "anthropic"

# PostgreSQL + pgvector
DATABASE_URL=postgresql://user:password@localhost:5432/legallens

# File storage (local for dev, S3 for prod)
STORAGE_BACKEND=local         # or "s3"
LOCAL_UPLOAD_DIR=./uploads

# S3 (only needed if STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=legallens-docs
AWS_REGION=ap-south-1

# App
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret
MAX_UPLOAD_SIZE_MB=20
